{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "GopherProxy — Live traffic, backend health, and rate limiting",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 10,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "rate(gopherproxy_processed_requests_total[1m])",
          "legendFormat": "Processed req/s",
          "refId": "A"
        },
        {
          "expr": "rate(gopherproxy_dropped_requests_total[1m])",
          "legendFormat": "Dropped req/s",
          "refId": "B"
        }
      ],
      "title": "Request Rate (processed vs dropped)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gopherproxy_request_duration_seconds_bucket[1m])) by (le, backend))",
          "legendFormat": "p50 — {{backend}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gopherproxy_request_duration_seconds_bucket[1m])) by (le, backend))",
          "legendFormat": "p95 — {{backend}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gopherproxy_request_duration_seconds_bucket[1m])) by (le, backend))",
          "legendFormat": "p99 — {{backend}}",
          "refId": "C"
        }
      ],
      "title": "Request Latency Percentiles (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 11,
      "title": "Backend Health",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 10
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "gopherproxy_active_backends",
          "legendFormat": "Active backends",
          "refId": "A"
        }
      ],
      "title": "Active Backends",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 18,
        "x": 6,
        "y": 10
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "gopherproxy_active_backends",
          "legendFormat": "Healthy backends",
          "refId": "A"
        }
      ],
      "title": "Backend Health Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 12,
      "title": "Totals",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 17
      },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "gopherproxy_processed_requests_total",
          "legendFormat": "Total Processed",
          "refId": "A"
        }
      ],
      "title": "Total Processed Requests",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 17
      },
      "id": 6,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "gopherproxy_dropped_requests_total",
          "legendFormat": "Total Dropped",
          "refId": "A"
        }
      ],
      "title": "Total Dropped Requests (rate-limited + no backend)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 17
      },
      "id": 7,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "rate(gopherproxy_processed_requests_total[5m]) / (rate(gopherproxy_processed_requests_total[5m]) + rate(gopherproxy_dropped_requests_total[5m]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "title": "Request Success Rate (5m)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "gopherproxy",
    "load-balancer",
    "go"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "GopherProxy Dashboard",
  "uid": "gopherproxy-main",
  "version": 1
}
