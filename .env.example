# Copy this file to .env and fill in your values.
# .env is already in .gitignore — NEVER commit real secrets.

# ── Build metadata ────────────────────────────────────────────────────────
VERSION=1.0.0
COMMIT=local

# ── Grafana credentials ───────────────────────────────────────────────────
# Change these before any deployment.
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ── Sentinel targets (comma-separated host:port) ──────────────────────────
# Override the default hard-coded list without rebuilding the image.
SENTINEL_TARGETS=host.docker.internal:8081,host.docker.internal:8082,host.docker.internal:8083
